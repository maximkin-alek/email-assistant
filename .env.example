## Сгенерируй ключ один раз и положи в .env:
## python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_ENCRYPTION_KEY=

## Gmail OAuth (итерация 3)
## 1) Создай OAuth Client (Web application) в Google Cloud Console
## 2) Authorized redirect URI: http://localhost:8000/oauth2/google/callback
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REDIRECT_URI=http://localhost:8000/oauth2/google/callback

## OpenRouter (итерация AI)
## AI (OpenAI-compatible). По умолчанию OpenRouter.
AI_BASE_URL=https://openrouter.ai/api/v1
AI_API_KEY=
AI_MODEL=anthropic/claude-3.5-haiku

## RouterAI (альтернатива OpenRouter): единый OpenAI-compatible API + оплата в рублях
## Документация: https://routerai.ru/docs/guides
## Пример дешёвой/сильной модели для задач по почте:
## AI_BASE_URL=https://routerai.ru/api/v1
## AI_API_KEY=... (твой ключ)
## AI_MODEL=deepseek/deepseek-v3.2

## Cursor (Cloud Agents key) — как использовать для AI в этом проекте
## Ключ с https://cursor.com/dashboard/cloud-agents относится к Cloud Agents API и НЕ является OpenAI-совместимым chat API.
## Для работы через OpenAI-compatible интерфейс используйте локальный прокси: cursor-api-proxy (Node.js + Cursor agent CLI).
##
## 1) Установи Node.js 18+ и Cursor agent CLI:
##    https://cursor.com/install  (далее: agent login)
## 2) Запусти прокси:
##    npx cursor-api-proxy
## 3) В Docker (web/worker) ходим на хост через host.docker.internal:
##    AI_BASE_URL=http://host.docker.internal:8765/v1
##    AI_API_KEY=unused   (или ключ, если ты включил CURSOR_BRIDGE_API_KEY в прокси)
##    AI_MODEL=gpt-5.4-nano-low  (или другую конкретную модель; на практике это стабильнее, чем auto)
##

## Backward-compat
OPENROUTER_API_KEY=
OPENROUTER_MODEL=

## IMAP (итерация 2)
YANDEX_IMAP_HOST=imap.yandex.ru
YANDEX_IMAP_PORT=993
YANDEX_IMAP_USER=
YANDEX_IMAP_PASSWORD=

MAILRU_IMAP_HOST=imap.mail.ru
MAILRU_IMAP_PORT=993
MAILRU_IMAP_USER=
MAILRU_IMAP_PASSWORD=
